{
  "name": "kalima",
  "author": "chairulakmal",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "docker compose up -d && nuxt dev",
    "build": "nuxt build",
    "start": "npx prisma db push --accept-data-loss && npx prisma db seed && node .output/server/index.mjs",
    "preview": "nuxt preview",
    "generate": "nuxt generate",
    "postinstall": "nuxt prepare",
    "db:push": "prisma db push",
    "db:reset": "prisma db push --force-reset",
    "db:seed": "tsx prisma/seed.ts",
    "generate:seed": "tsx scripts/generate-seed.ts",
    "deploy": "railway up -d --service kalima"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@pinia/nuxt": "^0.9.0",
    "@prisma/client": "^6.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "nuxt": "^3.13.0",
    "prisma": "^6.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}